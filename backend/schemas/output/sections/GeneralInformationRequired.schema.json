            "OK",
            "OR",
            "PA",
            "PR",
            "PW",
            "RI",
            "SC",
            "SD",
            "TN",
            "TX",
            "UT",
            "VA",
            "VI",
            "VT",
            "WA",
            "WI",
            "WV",
            "WY"
         ]
      },
      "auditor_zip": {
         "oneOf": [
            {
               "pattern": "^[0-9]{5}(?:[0-9]{4})?$",
               "type": "string"
            },
            {
               "const": "GSA_MIGRATION",
               "type": "string"
            }
         ]
      },
      "ein": {
         "oneOf": [
            {
               "pattern": "^[0-9]{9}$",
               "type": "string"
            },
            {
               "const": "GSA_MIGRATION",
               "type": "string"
            }
         ]
      },
      "ein_not_an_ssn_attestation": {
         "type": "boolean"
      },
      "is_usa_based": {
         "type": "boolean"
      },
      "met_spending_threshold": {
         "type": "boolean"
      },
      "multiple_eins_covered": {
         "type": "boolean"
      },
      "multiple_ueis_covered": {
         "type": "boolean"
      },
      "secondary_auditors_exist": {
         "type": "boolean"
      },
      "user_provided_organization_type": {
         "description": "Org type",
         "enum": [
            "state",
            "local",
            "tribal",
            "higher-ed",
            "non-profit",
            "unknown",
            "none"
         ],
         "title": "OrganizationType",
         "type": "string"
      }
   },
   "required": [
      "audit_type",
      "auditee_address_line_1",
      "auditee_city",
      "auditee_contact_name",
      "auditee_contact_title",
      "auditee_email",
