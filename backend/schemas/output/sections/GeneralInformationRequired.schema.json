{
   "$id": "http://example.org/generalinformation",
   "$schema": "https://json-schema.org/draft/2019-09/schema#",
   "additionalProperties": false,
   "allOf": [
      {
         "anyOf": [
            {
               "if": {
                  "properties": {
                     "audit_period_covered": {
                        "const": "annual"
                     }
                  }
               },
               "then": {
                  "not": {
                     "required": [
                        "audit_period_other_months"
                     ]
                  }
               }
            },
            {
               "if": {
                  "properties": {
                     "audit_period_covered": {
                        "const": "biennial"
                     }
                  }
               },
               "then": {
                  "not": {
                     "required": [
                        "audit_period_other_months"
                     ]
                  }
               }
            },
            {
               "if": {
                  "properties": {
                     "audit_period_covered": {
                        "const": "other"
                     }
                  }
               },
               "then": {
                  "required": [
                     "audit_period_other_months"
                  ]
               }
            }
         ]
      },
      {
         "if": {
            "properties": {
               "auditor_country": {
                  "const": "USA"
               }
            }
         },
         "then": {
            "allOf": [
               {
                  "not": {
                     "required": [
                        "auditor_international_address"
                     ]
                  }
               },
               {
                  "required": [
                     "auditor_address_line_1",
                     "auditor_city",
                     "auditor_state",
                     "auditor_zip"
                  ]
               }
            ]
         }
      },
      {
         "if": {
            "properties": {
               "auditor_country": {
                  "not": {
                     "const": "USA"
                  }
               }
            }
         },
         "then": {
            "allOf": [
               {
                  "not": {
                     "required": [
                        "auditor_address_line_1",
                        "auditor_city",
                        "auditor_state",
                        "auditor_zip"
                     ]
                  }
               },
               {
                  "required": [
                     "auditor_international_address"
                  ]
               }
            ]
         }
      }
   ],
   "metamodel_version": "1.7.0",
   "properties": {
      "audit_period_covered": {
         "description": "Period type of audit being submitted",
         "enum": [
            "annual",
            "biennial",
            "other"
         ],
         "title": "AuditPeriod",
         "type": "string"
      },
      "audit_period_other_months": {
         "maxLength": 2,
         "minLength": 0,
         "pattern": "^0?[1-9]$|^1[0-8]$",
         "type": "string"
      },
      "audit_type": {
         "oneOf": [
            {
               "description": "Type of audit being submitted",
               "enum": [
                  "program-specific",
                  "single-audit"
               ],
               "title": "AuditType",
               "type": "string"
            },
            {
               "const": "GSA_MIGRATION",
               "type": "string"
            }
         ]
      },
      "auditee_address_line_1": {
         "maxLength": 100,
         "minLength": 2,
         "type": "string"
      },
      "auditee_city": {
         "maxLength": 100,
         "minLength": 2,
         "type": "string"
      },
      "auditee_contact_name": {
         "maxLength": 100,
         "minLength": 2,
         "type": "string"
      },
      "auditee_contact_title": {
         "maxLength": 100,
         "minLength": 2,
         "type": "string"
      },
      "auditee_email": {
         "oneOf": [
            {
               "format": "email",
               "maxLength": 320,
               "minLength": 6,
               "type": "string"
            },
            {
               "const": "GSA_MIGRATION",
               "type": "string"
            }
         ],
         "type": "string"
      },
      "auditee_fiscal_period_end": {
         "format": "date"
      },
      "auditee_fiscal_period_start": {
         "format": "date"
      },
      "auditee_name": {
         "maxLength": 100,
         "minLength": 2,
         "type": "string"
      },
      "auditee_phone": {
         "pattern": "^^(\\+0?1\\s)?\\(?\\d{3}\\)?[\\s.-]?\\d{3}[\\s.-]?\\d{4}$",
         "type": "string"
      },
      "auditee_state": {
         "description": "US States 2-letter abbreviations",
         "enum": [
            "AK",
            "AL",
            "AR",
            "AS",
            "AZ",
            "CA",
            "CO",
            "CT",
            "DC",
            "DE",
            "FL",
            "FM",
            "GA",
            "GU",
            "HI",
            "IA",
            "ID",
            "IL",
            "IN",
            "KS",
            "KY",
            "LA",
            "MA",
            "MD",
            "ME",
            "MH",
            "MI",
            "MN",
            "MO",
            "MP",
            "MS",
            "MT",
            "NC",
            "ND",
            "NE",
            "NH",
            "NJ",
            "NM",
            "NV",
            "NY",
            "OH",
            "OK",
            "OR",
            "PA",
            "PR",
            "PW",
            "RI",
            "SC",
            "SD",
            "TN",
            "TX",
            "UT",
            "VA",
            "VI",
            "VT",
            "WA",
            "WI",
            "WV",
            "WY"
         ]
      },
      "auditee_uei": {
         "oneOf": [
            {
               "allOf": [
                  {
                     "maxLength": 12,
                     "minLength": 12
                  },
                  {
                     "pattern": "^[A-HJ-NP-Z1-9][A-HJ-NP-Z0-9]+$"
                  },
                  {
                     "pattern": "^(?![A-HJ-NP-Z1-9]+[A-HJ-NP-Z0-9]*?[0-9]{9})[A-HJ-NP-Z0-9]*$"
                  },
                  {
                     "pattern": "^(?![0-9]{9})"
                  }
               ],
               "type": "string"
            },
            {
               "const": "GSA_MIGRATION",
               "type": "string"
            }
         ]
      },
      "auditee_zip": {
         "oneOf": [
            {
               "pattern": "^[0-9]{5}(?:[0-9]{4})?$",
               "type": "string"
            },
            {
               "const": "GSA_MIGRATION",
               "type": "string"
            }
         ]
      },
      "auditor_address_line_1": {
         "maxLength": 100,
         "minLength": 0,
         "type": "string"
      },
      "auditor_city": {
         "maxLength": 100,
         "minLength": 0,
         "type": "string"
      },
      "auditor_contact_name": {
         "maxLength": 100,
         "minLength": 2,
         "type": "string"
      },
      "auditor_contact_title": {
         "maxLength": 100,
         "minLength": 2,
         "type": "string"
      },
      "auditor_country": {
         "description": "USA or International",
         "enum": [
            "USA",
            "non-USA"
         ],
         "title": "CountryType",
         "type": "string"
      },
      "auditor_ein": {
         "oneOf": [
            {
               "pattern": "^[0-9]{9}$",
               "type": "string"
            },
            {
               "const": "GSA_MIGRATION",
               "type": "string"
            }
         ]
      },
      "auditor_ein_not_an_ssn_attestation": {
         "type": "boolean"
      },
      "auditor_email": {
         "oneOf": [
            {
               "format": "email",
               "maxLength": 320,
               "minLength": 6,
               "type": "string"
            },
            {
               "const": "GSA_MIGRATION",
               "type": "string"
            }
         ]
      },
      "auditor_firm_name": {
         "maxLength": 100,
         "minLength": 2,
         "type": "string"
      },
      "auditor_international_address": {
         "maxLength": 100,
         "minLength": 0,
         "type": "string"
      },
      "auditor_phone": {
         "pattern": "^^(\\+0?1\\s)?\\(?\\d{3}\\)?[\\s.-]?\\d{3}[\\s.-]?\\d{4}$",
         "type": "string"
      },
      "auditor_state": {
         "description": "US States 2-letter abbreviations",
         "enum": [
            "AK",
            "AL",
            "AR",
            "AS",
            "AZ",
            "CA",
