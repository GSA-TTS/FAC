      "auditor_phone",
      "ein",
      "ein_not_an_ssn_attestation",
      "is_usa_based",
      "met_spending_threshold",
      "multiple_eins_covered",
      "multiple_ueis_covered",
      "secondary_auditors_exist",
      "user_provided_organization_type",
